# DeskIn 配置範本
# 複製此文件為 config.env 並修改實際值

# DeskIn 帳號（如果需要 API 整合）
DESKIN_USERNAME="your_email@example.com"
DESKIN_PASSWORD="your_password_or_app_token"

# 目標設備配置
DESKIN_DEVICE_NAME="JOESPC"

# 設備 MAC 地址（用於 WoL）
# 在 Windows 上取得 MAC 地址：
#   ipconfig /all
#   或 getmac /v
DESKIN_DEVICE_MAC="00:11:22:33:44:55"

# 設備 IP 地址（用於 ping 測試）
DESKIN_DEVICE_IP="192.168.1.100"

# WoL 配置
WOL_BROADCAST_IP="255.255.255.255"
WOL_PORT="9"
WOL_COUNT="3"
WOL_INTERVAL="1"

# 等待配置
WAKE_TIMEOUT="120"
WAKE_CHECK_INTERVAL="5"

# ComfyUI 整合（可選）
COMFYUI_HOST="192.168.1.100"
COMFYUI_PORT="8188"
