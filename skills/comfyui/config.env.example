# ComfyUI 配置範本
# 複製此文件為 config.env 並修改實際值

# 桌機 IP 位置
COMFYUI_HOST="192.168.1.100"

# ComfyUI 端口
COMFYUI_PORT="8188"

# 輸出目錄
COMFYUI_OUTPUT_DIR="/home/joechiang/.openclaw/workspace/comfyui_output"

# 預設參數
COMFYUI_DEFAULT_STEPS="20"
COMFYUI_DEFAULT_CFG="8"
COMFYUI_DEFAULT_WIDTH="1024"
COMFYUI_DEFAULT_HEIGHT="1024"
COMFYUI_DEFAULT_TIMEOUT="300"
